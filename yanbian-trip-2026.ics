BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//ChatGPT//Yanbian Trip 2026 Ultimate//CN
CALSCALE:GREGORIAN
METHOD:PUBLISH
X-WR-CALNAME:2026延边亲子游终极版
X-WR-TIMEZONE:Asia/Shanghai

BEGIN:VEVENT
UID:20260715-checklist@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🚗 出发前检查：证件、行李、订单
DTSTART;TZID=Asia/Shanghai:20260715T210000
DTEND;TZID=Asia/Shanghai:20260715T213000
DESCRIPTION:检查身份证、驾驶证、手机、充电器、充电宝、酒店订单、租车订单、孩子衣物、雨伞、常备药。
END:VEVENT

BEGIN:VEVENT
UID:20260716-drive-airport@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🚙 潍坊出发前往青岛胶东机场
DTSTART;TZID=Asia/Shanghai:20260716T051000
DTEND;TZID=Asia/Shanghai:20260716T071000
DESCRIPTION:推荐导航：青岛胶东国际机场停车楼。建议停机场停车楼，带孩子和行李更省心。
END:VEVENT

BEGIN:VEVENT
UID:20260716-flight-out@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:✈️ MU5671 青岛 → 延吉
DTSTART;TZID=Asia/Shanghai:20260716T093500
DTEND;TZID=Asia/Shanghai:20260716T113000
DESCRIPTION:建议提前2小时到达机场；注意身份证件、充电宝容量标识。
END:VEVENT

BEGIN:VEVENT
UID:20260716-car-pickup@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🚗 延吉机场取车：大众途岳
DTSTART;TZID=Asia/Shanghai:20260716T123000
DTEND;TZID=Asia/Shanghai:20260716T130000
DESCRIPTION:取车地点：延吉朝阳川国际机场。验车拍照：四个轮胎、前后保险杠、油量、公里数、车身划痕。
END:VEVENT

BEGIN:VEVENT
UID:20260716-hotel-yanji@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🏨 入住汉庭酒店（延吉西市场店）
DTSTART;TZID=Asia/Shanghai:20260716T140000
DTEND;TZID=Asia/Shanghai:20260716T143000
DESCRIPTION:入住时间：14:00后。地址：延吉市新华街57-2号。入住人：张政。
END:VEVENT

BEGIN:VEVENT
UID:20260716-yanji-city@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🌆 延吉市区：西市场、延边大学周边
DTSTART;TZID=Asia/Shanghai:20260716T150000
DTEND;TZID=Asia/Shanghai:20260716T210000
DESCRIPTION:轻松适应日：西市场、延边大学周边、人民公园。当天不安排太累。
END:VEVENT

BEGIN:VEVENT
UID:20260717-longjing@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🌾 龙井一日游
DTSTART;VALUE=DATE:20260717
DTEND;VALUE=DATE:20260718
DESCRIPTION:海兰江风光、龙井地标、乡村体验、咖啡庄园。晚上返回延吉。
END:VEVENT

BEGIN:VEVENT
UID:20260718-tumen@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🇨🇳 图们边境游
DTSTART;VALUE=DATE:20260718
DTEND;VALUE=DATE:20260719
DESCRIPTION:图们国门、中朝边境、界碑、铁路口岸。适合带孩子看边境地理。
END:VEVENT

BEGIN:VEVENT
UID:20260719-yanji-checkout@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:📦 汉庭酒店退房
DTSTART;TZID=Asia/Shanghai:20260719T090000
DTEND;TZID=Asia/Shanghai:20260719T093000
DESCRIPTION:汉庭酒店（延吉西市场店）12:00前退房，提前整理行李。
END:VEVENT

BEGIN:VEVENT
UID:20260719-folk-park@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🏞️ 中国朝鲜族民俗园
DTSTART;TZID=Asia/Shanghai:20260719T100000
DTEND;TZID=Asia/Shanghai:20260719T120000
DESCRIPTION:可作为延吉退房后到珲春前的半日安排，适合拍照打卡。
END:VEVENT

BEGIN:VEVENT
UID:20260719-drive-hunchun@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🚗 延吉 → 珲春
DTSTART;TZID=Asia/Shanghai:20260719T130000
DTEND;TZID=Asia/Shanghai:20260719T150000
DESCRIPTION:约1.5小时车程，途中注意休息。
END:VEVENT

BEGIN:VEVENT
UID:20260719-hotel-hunchun@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🏨 入住如家商旅酒店（珲春迎新路商业中心店）
DTSTART;TZID=Asia/Shanghai:20260719T150000
DTEND;TZID=Asia/Shanghai:20260719T153000
DESCRIPTION:入住时间：14:00后。地址：珲春市新安街道迎新路250-5号附近。入住人：张政。
END:VEVENT

BEGIN:VEVENT
UID:20260720-fangchuan@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🌏 防川风景区：一眼望三国
DTSTART;VALUE=DATE:20260720
DTEND;VALUE=DATE:20260721
DESCRIPTION:本次旅行重点日：龙虎阁、土字牌、东方第一村、一眼望三国。建议提前下载离线地图。
END:VEVENT

BEGIN:VEVENT
UID:20260721-tiger-wetland@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🐯 东北虎豹国家公园科普馆 + 敬信湿地
DTSTART;VALUE=DATE:20260721
DTEND;VALUE=DATE:20260722
DESCRIPTION:亲子游重点日：上午虎豹国家公园科普馆，下午敬信湿地，晚上可逛珲春市区。
END:VEVENT

BEGIN:VEVENT
UID:20260722-hunchun-checkout@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🏨 如家商旅酒店退房
DTSTART;TZID=Asia/Shanghai:20260722T083000
DTEND;TZID=Asia/Shanghai:20260722T090000
DESCRIPTION:12:00前退房，因10:30需延吉机场还车，建议早退房早出发。
END:VEVENT

BEGIN:VEVENT
UID:20260722-car-return@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🚗 延吉机场还车
DTSTART;TZID=Asia/Shanghai:20260722T103000
DTEND;TZID=Asia/Shanghai:20260722T110000
DESCRIPTION:还车地点：延吉朝阳川国际机场。检查随身物品，保留验车记录。
END:VEVENT

BEGIN:VEVENT
UID:20260722-flight-back@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:✈️ MU5672 延吉 → 青岛
DTSTART;TZID=Asia/Shanghai:20260722T125000
DTEND;TZID=Asia/Shanghai:20260722T150000
DESCRIPTION:还车后办理值机，注意证件和随身物品。
END:VEVENT

BEGIN:VEVENT
UID:20260722-drive-home@yanbian-trip-2026
DTSTAMP:20260614T000000Z
SUMMARY:🏠 青岛胶东机场返回潍坊
DTSTART;TZID=Asia/Shanghai:20260722T150000
DTEND;TZID=Asia/Shanghai:20260722T173000
DESCRIPTION:取车后返程，预计傍晚到家。
